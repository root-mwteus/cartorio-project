# Supabase — painel do projeto > Project Settings > API
# SUPABASE_URL é a "Project URL" (sem o sufixo /rest/v1/)
# SUPABASE_ANON_KEY é a chave "anon / public"
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Resend — painel > API Keys
RESEND_API_KEY=

# E-mail que recebe as notificações do formulário de contato.
# Com o domínio sandbox padrão (onboarding@resend.dev), só funciona
# se for o mesmo e-mail dono da conta Resend.
CONTACT_NOTIFICATION_EMAIL=

# Upstash Redis — painel do banco > aba "REST API"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
